{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://harness.lab/schemas/ws-health-payload.json",
  "title": "HealthEventPayload",
  "description": "Payload schema for health-related WebSocket events",
  "type": "object",
  "properties": {
    "warning_id": {
      "type": "string",
      "description": "Unique warning identifier"
    },
    "component": {
      "type": "string",
      "enum": ["postgres", "redis", "sandbox", "knowledge", "provider", "artifacts", "workers"],
      "description": "Affected component"
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"],
      "default": "medium",
      "description": "Warning severity level"
    },
    "message": {
      "type": "string",
      "description": "Warning or status message"
    },
    "details": {
      "type": "object",
      "description": "Additional details about the event"
    },
    "suggested_action": {
      "type": "string",
      "description": "Suggested remediation action"
    },
    "ready": {
      "type": "boolean",
      "description": "Component readiness status"
    },
    "doctor_ready": {
      "type": "boolean",
      "description": "Overall doctor readiness"
    },
    "warnings_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Count of active warnings"
    },
    "check_results": {
      "type": "object",
      "description": "Component check results",
      "properties": {
        "postgres_ready": {"type": "boolean"},
        "redis_ready": {"type": "boolean"},
        "model_ready": {"type": "boolean"},
        "sandbox_ready": {"type": "boolean"},
        "knowledge_ready": {"type": "boolean"},
        "artifacts_ready": {"type": "boolean"}
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "component": {"type": "string"},
          "severity": {"type": "string"},
          "message": {"type": "string"}
        }
      },
      "description": "Array of active warnings (for snapshots)"
    },
    "execution_plane": {
      "type": "object",
      "description": "Execution plane status details"
    },
    "provider": {
      "type": "object",
      "description": "Model provider status details"
    },
    "filters": {
      "type": "object",
      "description": "Active filters for the connection"
    }
  },
  "required": ["component"]
}